<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # HTTPS-Zwang: Alle Anfragen auf HTTPS umleiten
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # www zu non-www Redirect (optional, für Konsistenz)
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

  # 301-Redirects: Alte URLs auf neue clean URLs umleiten
  RewriteRule ^en/index\.html$ / [L,R=301]
  RewriteRule ^coaching\.html$ / [L,R=301]
  RewriteRule ^en/offers\.html$ /angebote [L,R=301]
  RewriteRule ^fr/offres\.html$ /angebote [L,R=301]

  # 301-Redirects für alte 404-URLs aus Google Search Console
  RewriteRule ^en/?$ / [L,R=301]
  RewriteRule ^fr/?$ / [L,R=301]
  RewriteRule ^en/privacy\.html$ / [L,R=301]
  RewriteRule ^angebote\.html$ / [L,R=301]
  RewriteRule ^ebook\.html$ / [L,R=301]
  RewriteRule ^buchen\.html$ / [L,R=301]
  RewriteRule ^termine/index\.php$ / [L,R=301]
  RewriteRule ^index\.html$ / [L,R=301]
  RewriteRule ^en/contact\.html$ / [L,R=301]
  RewriteRule ^datenschutz\.html$ /datenschutz [L,R=301]

  # Query-Parameter-Redirects
  RewriteCond %{QUERY_STRING} ^lang=en$ [NC]
  RewriteRule ^$ /? [L,R=301]
  RewriteCond %{QUERY_STRING} ^s= [NC]
  RewriteRule ^$ /? [L,R=301]
  
  # Clean URLs: Verzeichnisse laden automatisch index.html
  # z.B. /kontakt/ -> /kontakt/index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.+)/$ $1/index.html [L]
  
  # URLs ohne .html-Endung ermöglichen
  # z.B. /datenschutz -> datenschutz.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
  
  # Fallback zur index.html für nicht gefundene Seiten
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.orbnet.de https://www.chatbase.co https://maps.googleapis.com https://maps.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; frame-src https://www.google.com https://www.orbnet.de https://www.chatbase.co; connect-src 'self' https://*.supabase.co https://www.chatbase.co https://static.orbnet.de https://www.google-analytics.com https://t.me;"
</IfModule>

# Browser-Caching für maximale Performance (PageSpeed 100)
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML - kurzes Caching für Updates
  ExpiresByType text/html "access plus 1 hour"
  
  # Assets mit Hash - 1 Jahr Caching
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # JSON/XML
  ExpiresByType application/json "access plus 1 day"
  ExpiresByType application/xml "access plus 1 day"
</IfModule>

# Cache-Control Headers für Assets
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff|woff2|ttf|eot|ico|jpg|jpeg|png|gif|svg|webp|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# GZIP Komprimierung
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Brotli Komprimierung (falls verfügbar)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
  AddOutputFilterByType BROTLI_COMPRESS application/xml application/xhtml+xml
  AddOutputFilterByType BROTLI_COMPRESS font/woff font/woff2
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# Korrekter MIME-Type für Webfonts und moderne Formate
<IfModule mod_mime.c>
  AddType font/woff .woff
  AddType font/woff2 .woff2
  AddType image/webp .webp
  AddType image/avif .avif
  AddType application/javascript .js
</IfModule>

# ETags deaktivieren (Cache-Busting durch Hashes)
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# Keep-Alive aktivieren
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>
