{
  "buildCommand": "npm run build && node scripts/prerender.js",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/en", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/en/", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/fr", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/fr/", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/en/privacy.html", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/angebote.html", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/ebook.html", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/buchen.html", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/termine/index.php", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/index.html", "destination": "https://www.fels-coach.de/", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
