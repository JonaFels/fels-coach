{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && node scripts/prerender.js",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/en", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/en/:path*", "destination": "https://www.fels-coach.de/", "statusCode": 301 },
    { "source": "/angebote.html", "destination": "/", "statusCode": 301 },
    { "source": "/ebook.html", "destination": "/", "statusCode": 301 },
    { "source": "/buchen.html", "destination": "/", "statusCode": 301 },
    { "source": "/termine/index.php", "destination": "/", "statusCode": 301 },
    { "source": "/index.html", "destination": "/", "statusCode": 301 },
    { "source": "/datenschutz.html", "destination": "/datenschutz", "statusCode": 301 },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fels-coach.de" }],
      "destination": "https://www.fels-coach.de/:path*",
      "statusCode": 301
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'; upgrade-insecure-requests;" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
